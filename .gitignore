# =====================================================
# HarborForge .gitignore
# Angular + Firebase + Capacitor
# =====================================================

# -----------------------------------------------------
# Angular build output
# -----------------------------------------------------
/dist/
/out-tsc/
/coverage/
/.angular/
/tmp/
/.cache/

# Angular CLI legacy
/.angular-cli.json
/.ng/

# -----------------------------------------------------
# Node dependencies
# -----------------------------------------------------
/node_modules/

# -----------------------------------------------------
# Logs
# -----------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# -----------------------------------------------------
# TypeScript
# -----------------------------------------------------
*.tsbuildinfo

# -----------------------------------------------------
# Environment files
# -----------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Angular environments

# Firebase local/emulator
firebase-debug.log
firebase-export/
.firebaserc.local

# -----------------------------------------------------
# IDE / Editors
# -----------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.orig

# -----------------------------------------------------
# Operating System Files
# -----------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------
# Testing
# -----------------------------------------------------
/test-results/
/playwright-report/
/e2e/test-output/

# -----------------------------------------------------
# Capacitor / Android
# -----------------------------------------------------
android/.gradle/
android/build/
android/app/build/

# Capacitor generated
android/capacitor-cordova-android-plugins/

# -----------------------------------------------------
# Temporary / local data
# -----------------------------------------------------
savegames/
temp/
tmp/
*.tmp
*.bak
*.local

# Local env files
.env
.env.local
.env.*.local

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# Builds
dist/
node_modules/
